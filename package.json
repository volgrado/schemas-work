{
  "name": "schemas-work",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "npm run assets:generate && vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "test:e2e": "playwright test",
    "test": "npm run test:e2e && npm run test:unit -- --run",
    "test:unit": "vitest",
    "test:components": "vitest src/lib/components/ --environment jsdom",
    "assets:generate": "node ./scripts/generate-assets.js"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.5",
    "@eslint/js": "^9.22.0",
    "@iconify/svelte": "^5.1.0",
    "@playwright/test": "^1.49.1",
    "@sveltejs/kit": "^2.22.0",
    "@sveltejs/adapter-static": "^3.0.0",
    "@testing-library/svelte": "^5.2.8",
    "@types/d3": "^7.4.3",
    "@types/deep-eql": "^4.0.2",
    "@types/katex": "^0.16.7",
    "@types/node": "^24.5.2",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-svelte": "^3.0.0",
    "globals": "^16.0.0",
    "jsdom": "^27.0.1",
    "playwright": "^1.53.0",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.3",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.20.0",
    "vite": "^7.0.4",
    "vitest": "^3.2.4",
    "vitest-browser-svelte": "^0.1.0"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@tiptap/core": "^3.6.1",
    "@tiptap/extension-blockquote": "^3.10.4",
    "@tiptap/extension-bold": "^3.6.1",
    "@tiptap/extension-bullet-list": "^3.6.1",
    "@tiptap/extension-collaboration": "^3.6.1",
    "@tiptap/extension-document": "^3.6.1",
    "@tiptap/extension-heading": "^3.6.1",
    "@tiptap/extension-history": "^3.6.1",
    "@tiptap/extension-image": "^3.6.1",
    "@tiptap/extension-list-item": "^3.6.1",
    "@tiptap/extension-paragraph": "^3.6.1",
    "@tiptap/extension-placeholder": "^3.6.1",
    "@tiptap/extension-text": "^3.6.1",
    "@tiptap/extension-youtube": "^3.6.1",
    "@tiptap/pm": "^3.6.1",
    "@tiptap/starter-kit": "^3.6.1",
    "@tiptap/suggestion": "^3.6.1",
    "browser-image-compression": "^2.0.2",
    "chart.js": "^4.5.1",
    "d3": "^7.9.0",
    "dexie": "^4.2.1",
    "edge-tts-client": "^1.0.2",
    "idb": "^8.0.3",
    "katex": "^0.16.11",
    "sharp": "^0.34.4",
